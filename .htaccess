# 🛡️ Upgrader Pay Hub - LiteSpeed Optimized Config
Options -Indexes
Options +FollowSymLinks

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. API: Forward requests starting with /api to Laravel
    RewriteRule ^api/(.*)$ api/public/index.php [L,QSA]

    # 2. Prevent rewrite loop for physical assets
    RewriteRule ^assets/(.*)$ - [L]
    RewriteRule ^index\.html$ - [L]

    # 3. Serve physical files/directories if they exist
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 4. SPA Fallback: ALL other requests go to index.html
    # Use index.html without leading slash for better compatibility
    RewriteRule . index.html [L]
</IfModule>
